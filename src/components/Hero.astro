---
import { Image } from 'astro:assets';
const { hero } = Astro.props;
---
<div class="hero">
  <div class="hero-left">
    <div class="hero-left-content">
      <div class="hero-eyebrow">{hero.eyebrow}</div>
      <h1 class="hero-headline">
        {hero.headline}<br /><strong>{hero.headlineStrong}</strong>
      </h1>
      <p class="hero-sub">{hero.sub}</p>
      <div class="hero-actions">
        <a href={`#${hero.cta.target}`} class="btn-primary">{hero.cta.label}</a>
        <a href={`#${hero.ghost.target}`} class="btn-ghost">{hero.ghost.label}</a>
      </div>
    </div>
    <div class="hero-image">
      <!-- Hero image: iStock standard licence, purchased 2026-03 -->
      <Image src="/ot-it-stack.svg" alt="OT/IT integration diagram" width={800} height={600} />
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-stats">
      {hero.stats.map(s => (
        <div class="stat-cell">
          <div class="stat-num mono">{s.num}</div>
          <div class="stat-label">{s.label}</div>
          <div class="stat-sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</div>