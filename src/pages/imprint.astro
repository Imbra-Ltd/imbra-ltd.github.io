---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
---
<Base title={`Imprint — ${site.meta.title}`} description="Legal information about Imbra OOD.">
  <main class="legal-page">
    <a href="/" class="legal-back">← Back</a>
    <div class="legal-label">Legal</div>
    <h1 class="legal-heading">Imprint</h1>

    <div class="legal-grid">
      <div class="legal-section">
        <div class="legal-section-title">Company</div>
        <div class="legal-section-body">
          <p>Imbra OOD</p>
          <p>ul. Tsar Simeon I 36<br />Varna, Bulgaria</p>
        </div>
      </div>

      <div class="legal-section">
        <div class="legal-section-title">Registration</div>
        <div class="legal-section-body">
          <p>BULSTAT / UIC: <span class="mono">XXXXXXXXX</span></p>
          <p>VAT Number: <span class="mono">BG XXXXXXXXX</span></p>
        </div>
      </div>

      <div class="legal-section">
        <div class="legal-section-title">Represented by</div>
        <div class="legal-section-body">
          <p>Branimir Georgiev<br />Managing Director</p>
        </div>
      </div>

      <div class="legal-section">
        <div class="legal-section-title">Contact</div>
        <div class="legal-section-body">
          <p><a href="mailto:contact@imbra.soft">contact@imbra.soft</a></p>
        </div>
      </div>

      <div class="legal-section">
        <div class="legal-section-title">Dispute Resolution</div>
        <div class="legal-section-body">
          <p>The European Commission provides a platform for online dispute resolution (ODR): <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr</a></p>
          <p>We are not obliged to participate in dispute resolution proceedings before a consumer arbitration board.</p>
        </div>
      </div>
    </div>
  </main>
</Base>